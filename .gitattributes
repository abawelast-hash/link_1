# Force LF line endings for shell scripts and env files
*.sh text eol=lf
*.env text eol=lf
.env* text eol=lf
*.blade.php text eol=lf
*.php text eol=lf
*.json text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.md text eol=lf
*.css text eol=lf
*.js text eol=lf

# Windows-only files keep CRLF
*.ps1 text eol=crlf
*.bat text eol=crlf
*.cmd text eol=crlf
